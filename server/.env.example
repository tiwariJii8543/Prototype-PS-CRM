# Preferred for Railway/managed MySQL:
# DATABASE_URL=mysql://username:password@host:port/database
DATABASE_URL=

# Or use the separate values below for local/dev setups:
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=replace-with-your-db-password
DB_NAME=ps_crm_db
JWT_SECRET=replace-with-a-long-random-secret
PORT=5000
DB_SSL=false

# Comma-separated origins allowed to call the API when frontend is hosted separately.
# Leave empty when serving the frontend from the same Express app.
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# Email Configuration (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
APP_URL=http://localhost:5000
ENABLE_EMAIL_NOTIFICATIONS=false
